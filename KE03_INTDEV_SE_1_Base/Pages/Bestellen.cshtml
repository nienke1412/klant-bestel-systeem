@page
@model KE03_INTDEV_SE_1_Base.Pages.BestellenModel
@{
	ViewData["Title"] = "Bestellen";
} 

<h2> Voer hier uw gegevens in:</h2>
<div class="VolledigOverzicht">
<div class="WinkelWagen1">
		
	<form class="Bestelformulier" action="/action_page.php">
			
		<div class="BetaalInfo">
					<label for="fname">Voornaam:</label>
					<input type="text" id="fname" name="fname">
		</div>		
		<div class="BetaalInfo">
					<label for="lname">Achternaam:</label>
					<input type="text" id="lname" name="lname">
		</div>
	
		<div class="BetaalInfo">
					<label for="fname">Land:</label>
					<input type="text" id="fname" name="fname">
		</div>
		<div class="BetaalInfo">
					<label for="fname">Postcode:</label>
					<input type="text" id="fname" name="fname">
		</div>
		<div class="BetaalInfo">
					<label for="fname">Huisnummer:</label>
					<input type="text" id="fname" name="fname">
		</div>
		<div class="BetaalInfo">
					<label for="fname">Straat:</label>
					<input type="text" id="fname" name="fname">
		</div>
	
	<div class="BetaalInfo">
				<label for="fname">Plaats:</label>
				<input type="text" id="fname" name="fname">
	</div>
	</form>
</div>
	
<div class="TotaalBedragWinkelwagen">
		<h1>Overzicht</h1>
	<div class="TotaalOverzicht">
		<div class="TotaalBlokje">
			<h4>Totaal artikelen</h4>
			<h4>€@Model.totaalbedrag</h4>
		</div>
		<div class="TotaalBlokje">
			<h4>Verzendkosten</h4>
			<h4>€3,95</h4>
		</div>
		</div>
		<div class="TotaalBlokje">
		<h4>Totaal bedrag</h4>
		<h4>€@Model.totaalVerzendBedrag</h4>
		
	</div>
		<div class="betaalOpties">
			<h4>Betaalopties</h4>
			<div class="form-check">
				<input class="form-check-input" type="radio" name="inlineRadioOptions" id="inlineRadio1" value="option1">
				<label class="form-check-label" for="inlineRadio1">Ideal | Wero</label>
			</div>
			<div class="form-check">
				<input class="form-check-input" type="radio" name="inlineRadioOptions" id="inlineRadio2" value="option2">
				<label class="form-check-label" for="inlineRadio2">Klarna</label>
			</div>
			<div class="form-check">
				<input class="form-check-input" type="radio" name="inlineRadioOptions" id="inlineRadio2" value="option2">
				<label class="form-check-label" for="inlineRadio2">Credit card</label>
			</div>
		</div>
		<form method="post" asp-page-handler="Betalen">
			<button onclick="location.href='Betaalt';" class="btn btn-outline-success">Betalen</button>
		</form>
	</div>
</div>